# IBR Checklists — Variáveis de ambiente
# Copie este arquivo para .env.local e preencha os valores
# Configure também no Vercel: Settings → Environment Variables

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://rjuulamozdhssgqrzfji.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InJqdXVsYW1vemRoc3NncXJ6ZmppIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODIyNjc5MjksImV4cCI6MjA5Nzg0MzkyOX0.xxpJLp5SCpQRxMcuDMo-XD8offX2hrVUC_bU9I8me2M

# Cloudflare Turnstile (captcha no cadastro)
# Obter em: https://dash.cloudflare.com → Turnstile → Add Site
# Usar "1x00000000000000000000AA" para testes
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# ─── SEGREDO DE SERVIDOR — nunca prefixar com NEXT_PUBLIC_, nunca commitar ───
# Assina os tokens de sessão emitidos por /api/auth/session. É o MESMO segredo
# que o Supabase usa para verificar JWTs, então os tokens são aceitos pelo
# PostgREST e enxergados pelas políticas de RLS via auth.jwt().
#
# Onde achar: Supabase Dashboard → Project Settings → API → JWT Settings →
#             "JWT Secret" (Legacy). NÃO é a service_role key.
SUPABASE_JWT_SECRET=

# ─── SEGREDOS DE PROVISIONAMENTO — usados só por /api/admin/provision ────────
# A service_role IGNORA o RLS por completo: com ela se lê e escreve qualquer
# linha de qualquer empresa. É a credencial mais perigosa do projeto. Se vazar,
# rotacione imediatamente no painel do Supabase.
# Onde achar: Project Settings → API → Project API keys → service_role.
SUPABASE_SERVICE_ROLE_KEY=

# Segredo compartilhado que autoriza a criação de empresas. Gere um valor longo
# e aleatório, por exemplo:  openssl rand -base64 32
PROVISION_SECRET=
